{
  "name": "@shutter-network/shutter-voting-sdk",
  "version": "0.0.0",
  "description": "TypeScript SDK for client-side encrypted voting on the Shutter Network: linearly homomorphic threshold ElGamal over BLS12-381 with vote-validity and decryption-share zero-knowledge proofs.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    "import": "./dist/index.mjs",
    "require": "./dist/index.js"
  },
  "scripts": {
    "test": "jest",
    "build": "tsup && cp src/crypto/blst/blst.wasm dist/blst.wasm"
  },
  "repository": {
    "type": "git",
    "url": "github.com/shutter-network/shutter-voting-sdk"
  },
  "author": "shutter-network",
  "license": "ISC",
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "browser-or-node": "^3.0.0",
    "buffer": "^6.0.3",
    "viem": "^2.23.2"
  },
  "keywords": [
    "shutter",
    "voting",
    "bls12-381",
    "threshold-encryption",
    "elgamal",
    "zero-knowledge"
  ]
}
