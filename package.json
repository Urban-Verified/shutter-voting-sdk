{
  "name": "@shutter-network/urban-verified-crypto",
  "version": "0.1.2",
  "description": "TypeScript SDK for client-side encrypted voting on the Shutter Network: linearly homomorphic threshold ElGamal over BLS12-381 with vote-validity and decryption-share zero-knowledge proofs.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "jest",
    "bench": "node --expose-gc ./node_modules/.bin/jest --config benchmarks/bench.config.js",
    "bench:wasm": "node --expose-gc ./node_modules/.bin/ts-node --transpile-only benchmarks/wasm-heap-verify-stress.ts",
    "gen-vectors": "ts-node scripts/gen-vectors.ts",
    "build": "tsup && cp src/crypto/blst/blst.wasm dist/blst.wasm"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Urban-Verified/shutter-voting-sdk.git"
  },
  "homepage": "https://github.com/Urban-Verified/shutter-voting-sdk#readme",
  "bugs": {
    "url": "https://github.com/Urban-Verified/shutter-voting-sdk/issues"
  },
  "author": "Shutter Network",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "fast-check": "^4.7.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "browser-or-node": "^3.0.0",
    "buffer": "^6.0.3",
    "viem": "^2.23.2"
  },
  "keywords": [
    "shutter",
    "voting",
    "bls12-381",
    "threshold-encryption",
    "elgamal",
    "zero-knowledge"
  ]
}
